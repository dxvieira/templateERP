
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HELPER FUNCTIONS
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * isEmployee: Checks if the user is in the roles_employees collection.
     * Note: In a prototype environment, you might need to create this document manually 
     * for your UID in the /roles_employees collection to gain full access.
     */
    function isEmployee() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_employees/$(request.auth.uid)) ||
        // Fallback for initial setup: allows first user or specific admin UIDs if needed
        request.auth.token.email_verified == true
      );
    }

    // --- COLLECTION RULES ---

    match /orders/{orderId} {
      allow read, write: if isEmployee();
    }

    match /expenses/{expenseId} {
      allow read, write: if isEmployee();
    }

    match /clients/{clientId} {
      allow read, write: if isEmployee();
    }

    match /suppliers/{supplierId} {
      allow read, write: if isEmployee();
    }

    match /counters/{counterId} {
      allow read, write: if isEmployee();
    }

    match /roles_employees/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    // Global deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
