rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HELPER FUNCTIONS
     */
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /suppliers/{supplierId} {
      allow read, write: if isSignedIn();
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /cashflow_manual/{entryId} {
      allow read, write: if isSignedIn();
    }

    match /accounts_payable/{payableId} {
      allow read, write: if isSignedIn();
    }

    // Regra explícita para a coleção de materiais e suprimentos
    // Implementação de wildcard recursivo para garantir permissão em operações de listagem (queries)
    match /materials/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /roles_employees/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // Global deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}