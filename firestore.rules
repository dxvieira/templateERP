
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Whitelist check: allows anyone to verify if a specific email is authorized
    match /authorized_emails/{email} {
      allow get: if true;
      allow list, write: if false; // Only manageable via Firebase Console for safety
    }

    // General operational documents: accessible only by authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
