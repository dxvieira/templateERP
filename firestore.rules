rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reset de Segurança Industrial: Libera leitura e escrita para qualquer usuário autenticado.
    // Isso elimina erros de permissão em terminais operacionais rápidos.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}