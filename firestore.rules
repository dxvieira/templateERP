
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Whitelist check: permite que qualquer pessoa verifique se um e-mail está autorizado antes do login
    match /authorized_emails/{email} {
      allow get: if true;
      allow list, write: if false; 
    }

    // Documentos operacionais: acessíveis apenas por usuários autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
