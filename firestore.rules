
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HELPER FUNCTIONS
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // Regras para configurações de interface do usuário
    match /user_settings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Regra de Suprimentos e Materiais
    match /materials/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /orders/{orderId} {
      allow read, create, delete: if isSignedIn();
      
      // Bloqueio de alteração do Prazo de Entrega durante updates
      allow update: if isSignedIn() && 
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['delivery_date', 'deliveryDate']) ||
          (request.resource.data.delivery_date == resource.data.delivery_date)
        );
    }

    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /suppliers/{supplierId} {
      allow read, write: if isSignedIn();
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /cashflow_manual/{entryId} {
      allow read, write: if isSignedIn();
    }

    match /accounts_payable/{payableId} {
      allow read, write: if isSignedIn();
    }

    match /roles_employees/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // Global deny - Proteção contra acessos não mapeados
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
