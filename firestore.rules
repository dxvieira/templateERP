
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HELPER FUNCTIONS
     */
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    // Regra de Suprimentos e Materiais
    // Usando wildcard recursivo para garantir que listagem e documentos sejam cobertos
    // Deployment trigger: 2025-03-01.06 - Force rules propagation for collection queries
    match /materials/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /orders/{orderId} {
      allow read, create, delete: if isSignedIn();
      
      // Bloqueio de alteração do Prazo de Entrega durante updates
      allow update: if isSignedIn() && 
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['delivery_date', 'deliveryDate']) ||
          (request.resource.data.delivery_date == resource.data.delivery_date)
        );
    }

    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /suppliers/{supplierId} {
      allow read, write: if isSignedIn();
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /cashflow_manual/{entryId} {
      allow read, write: if isSignedIn();
    }

    match /accounts_payable/{payableId} {
      allow read, write: if isSignedIn();
    }

    match /roles_employees/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // Global deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
