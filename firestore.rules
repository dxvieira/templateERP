
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VISCOMM COMMAND CENTER - SECURE RULES
     * 
     * Core Philosophy:
     * - Verified Identity: Only authenticated users (Password, Google or Anonymous) can access.
     * - Data Integrity: Document IDs must match the internal 'id' field for creations and updates.
     */

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // --- Collection Rules ---

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == orderId;
      allow update: if isSignedIn() && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && resource != null;
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == clientId;
      allow update: if isSignedIn() && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && resource != null;
    }

    match /kpis/{kpiId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == kpiId;
      allow update: if isSignedIn() && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && resource != null;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
