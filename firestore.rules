
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROTOCOLO DE SEGURANÇA IMPACTO - OPERAÇÃO TOTAL
     * Permite leitura e escrita para qualquer usuário autenticado no sistema.
     * Isso resolve erros de permissão em campos específicos como 'delivery_date'.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
