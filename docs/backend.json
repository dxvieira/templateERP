
{
  "entities": {
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents a customer order within the Visual Communication ERP.",
      "properties": {
        "id": { "type": "string" },
        "client": { "type": "string" },
        "status": { "type": "string" },
        "delivery_date": { "type": "string", "format": "date" },
        "total_value": { "type": "number" },
        "amount_paid": { "type": "number" },
        "balance_due": { "type": "number" },
        "down_payment": { "type": "number" },
        "installments": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "client", "status", "createdAt"]
    },
    "AuthorizedEmail": {
      "title": "AuthorizedEmail",
      "type": "object",
      "description": "Whitelist of emails allowed to register in the system.",
      "properties": {
        "email": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Production orders."
    },
    "/authorized_emails/{email}": {
      "schema": { "$ref": "#/backend/entities/AuthorizedEmail" },
      "description": "Whitelist for registration control."
    }
  }
}
