
{
  "entities": {
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents a customer order within the Visual Communication ERP.",
      "properties": {
        "id": { "type": "string" },
        "client": { "type": "string" },
        "status": { "type": "string" },
        "delivery_date": { "type": "string", "format": "date" },
        "total_value": { "type": "number" },
        "amount_paid": { "type": "number" },
        "balance_due": { "type": "number" },
        "installments": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "client", "status", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CashflowEntry": {
      "title": "CashflowEntry",
      "type": "object",
      "description": "Manual financial entries not linked directly to an Order.",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "date": { "type": "string", "format": "date" },
        "account": { "type": "string" },
        "method": { "type": "string" }
      }
    },
    "AccountPayable": {
      "title": "AccountPayable",
      "type": "object",
      "description": "Bills and commitments to be paid by the company.",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "supplier": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/orders/{orderId}",
        "definition": { "entityName": "Order", "description": "Production orders." }
      },
      {
        "path": "/expenses/{expenseId}",
        "definition": { "entityName": "Expense", "description": "Business expenses." }
      },
      {
        "path": "/cashflow_manual/{entryId}",
        "definition": { "entityName": "CashflowEntry", "description": "Manual cashflow entries." }
      },
      {
        "path": "/accounts_payable/{payableId}",
        "definition": { "entityName": "AccountPayable", "description": "Company bills to pay." }
      }
    ]
  }
}
