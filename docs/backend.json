
{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Uma ordem de serviço no ERP VisComm",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "client_name": { "type": "string" },
        "os_number": { "type": "number" },
        "status": { 
          "type": "string",
          "enum": ["Arte", "Impressão", "Serralheria", "Acabamento", "Instalação", "Entregue"]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "deadline": { "type": "string", "format": "date" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "desc": { "type": "string" },
              "qty": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "payment_method": { "type": "string" },
        "total_value": { "type": "number" }
      },
      "required": ["client_name", "os_number", "status", "deadline"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "#/backend/entities/Order",
      "description": "Coleção de ordens de serviço do sistema"
    }
  }
}
