
{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a customer order within the VisComm Command Center application.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the order (Doc ID)."
        },
        "client": {
          "type": "string",
          "description": "Client name."
        },
        "emissionDate": {
          "type": "string",
          "format": "date"
        },
        "deliveryDate": {
          "type": "string",
          "format": "date"
        },
        "seller": {
          "type": "string"
        },
        "observations": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "Arte",
            "Impressão",
            "Serralheria",
            "Acabamento",
            "Instalação",
            "Entregue"
          ]
        },
        "paymentMethod": {
          "type": "string"
        },
        "machine": {
          "type": "string"
        },
        "installments": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "desc": {
                "type": "string"
              },
              "size": {
                "type": "string"
              },
              "quantity": {
                "type": "number"
              },
              "unitValue": {
                "type": "number"
              }
            }
          }
        },
        "totalValue": {
          "type": "number"
        },
        "isPriority": {
          "type": "boolean"
        },
        "isDelayed": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "client"
      ]
    },
    "Client": {
      "title": "Client",
      "description": "Customer information.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "properties": {
            "zip": { "type": "string" },
            "street": { "type": "string" },
            "neighborhood": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "number": { "type": "string" },
            "complement": { "type": "string" }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id"]
    },
    "Kpi": {
      "title": "Kpi",
      "description": "Performance indicators.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "arte": {
          "type": "number"
        },
        "impressao": {
          "type": "number"
        },
        "acabamento": {
          "type": "number"
        },
        "concluido": {
          "type": "number"
        }
      },
      "required": [
        "id"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google"
    ]
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/backend/entities/Order"
      },
      "description": "Stores customer orders."
    },
    "/clients/{clientId}": {
      "schema": {
        "$ref": "#/backend/entities/Client"
      },
      "description": "Stores customer contact information."
    },
    "/kpis/{kpiId}": {
      "schema": {
        "$ref": "#/backend/entities/Kpi"
      },
      "description": "Stores performance metrics."
    }
  }
}
