
{
  "entities": {
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a customer order within the Visual Communication ERP.",
      "properties": {
        "id": { "type": "string" },
        "client": { "type": "string" },
        "status": { "type": "string" },
        "delivery_date": { "type": "string", "format": "date" },
        "total_value": { "type": "number" },
        "amount_paid": { "type": "number" },
        "balance_due": { "type": "number" },
        "installments": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "client", "status", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "Supplier": {
      "title": "Supplier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "mobile": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/orders/{orderId}",
        "definition": { "entityName": "Order", "description": "Production orders." }
      },
      {
        "path": "/expenses/{expenseId}",
        "definition": { "entityName": "Expense", "description": "Business expenses." }
      },
      {
        "path": "/clients/{clientId}",
        "definition": { "entityName": "Client", "description": "Customer database." }
      },
      {
        "path": "/suppliers/{supplierId}",
        "definition": { "entityName": "Supplier", "description": "Supplier database." }
      },
      {
        "path": "/counters/{counterId}",
        "definition": { "entityName": "Counter", "description": "System counters for ID generation." }
      }
    ]
  }
}
