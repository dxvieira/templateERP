{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a customer order with integrated financial tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "client": { "type": "string" },
        "clientId": { "type": "string" },
        "emissionDate": { "type": "string", "format": "date" },
        "deliveryDate": { "type": "string", "format": "date" },
        "seller": { "type": "string" },
        "observations": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["Arte", "Impressão", "Serralheria", "Acabamento", "Instalação", "Entregue"]
        },
        "paymentMethod": { "type": "string" },
        "machine": { "type": "string" },
        "installments": { "type": "number" },
        "destinationAccount": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "desc": { "type": "string" },
              "quantity": { "type": "number" },
              "unitValue": { "type": "number" },
              "productCode": { "type": "string" }
            }
          }
        },
        "totalValue": { "type": "number" },
        "amountPaid": { "type": "number", "description": "Total sum of all recorded payments." },
        "balanceDue": { "type": "number", "description": "Remaining amount to be paid." },
        "paymentHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "amount": { "type": "number" },
              "date": { "type": "string", "format": "date" },
              "method": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "client"]
    },
    "Client": {
      "title": "Client",
      "description": "Customer information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Information about material and service providers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "email": { "type": "string" },
        "landline": { "type": "string" },
        "mobile": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Records of financial outputs/costs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "description", "value", "date"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google"]
  },
  "firestore": {
    "/orders/{orderId}": { "schema": { "$ref": "#/backend/entities/Order" }, "description": "Stores customer orders." },
    "/clients/{clientId}": { "schema": { "$ref": "#/backend/entities/Client" }, "description": "Stores customer contact information." },
    "/suppliers/{supplierId}": { "schema": { "$ref": "#/backend/entities/Supplier" }, "description": "Stores supplier information." },
    "/expenses/{expenseId}": { "schema": { "$ref": "#/backend/entities/Expense" }, "description": "Stores financial outputs." }
  }
}