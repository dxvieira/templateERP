
{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a customer order within the VisComm Command Center application.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "client": {
          "type": "string"
        },
        "clientId": {
          "type": "string"
        },
        "emissionDate": {
          "type": "string",
          "format": "date"
        },
        "deliveryDate": {
          "type": "string",
          "format": "date"
        },
        "seller": {
          "type": "string"
        },
        "observations": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "Arte",
            "Impressão",
            "Serralheria",
            "Acabamento",
            "Instalação",
            "Entregue"
          ]
        },
        "paymentMethod": {
          "type": "string"
        },
        "machine": {
          "type": "string"
        },
        "installments": {
          "type": "string"
        },
        "weekly_priority": {
          "type": "boolean",
          "description": "Flag to mark order as a priority for the current week."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "desc": {
                "type": "string",
                "description": "Material or service description"
              },
              "size": {
                "type": "string"
              },
              "quantity": {
                "type": "number"
              },
              "unitValue": {
                "type": "number"
              },
              "observation": {
                "type": "string",
                "description": "Technical details for production"
              }
            }
          }
        },
        "totalValue": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "client"
      ]
    },
    "Client": {
      "title": "Client",
      "description": "Customer information.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Information about material and service providers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "email": { "type": "string" },
        "landline": { "type": "string" },
        "mobile": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google"
    ]
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/backend/entities/Order"
      },
      "description": "Stores customer orders."
    },
    "/clients/{clientId}": {
      "schema": {
        "$ref": "#/backend/entities/Client"
      },
      "description": "Stores customer contact information."
    },
    "/suppliers/{supplierId}": {
      "schema": {
        "$ref": "#/backend/entities/Supplier"
      },
      "description": "Stores supplier information."
    }
  }
}
